# Copy this file to .env.local and fill in your values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FIGURITAS_APP_ENABLED=false

# --- Cloudflare Pages deployment ---
# Set these in Cloudflare Dashboard → Pages → album-world-cup → Settings → Environment variables:
#
# Build environment (for next build to inline NEXT_PUBLIC_* values):
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#
# Production / Preview environment (for worker runtime):
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#   NEXT_PUBLIC_APP_URL
